{
  "name": "vue3-rbac-admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dev": "pnpm run typecheck && vite build --mode development",
    "build:staging": "pnpm run typecheck && vite build --mode staging",
    "build:production": "pnpm run typecheck && vite build --mode production",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "pnpm run typecheck && pnpm run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@iconify-icons/ep": "^1.2.12",
    "@iconify-icons/ri": "^1.2.10",
    "@iconify/vue": "^5.0.0",
    "axios": "^1.9.0",
    "element-plus": "^2.11.3",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/mdi": "^1.2.3",
    "@types/node": "^24.0.1",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.90.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-icons": "^22.3.0",
    "vite": "^7.1.3",
    "vite-plugin-mock": "^3.0.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.0.6"
  }
}
